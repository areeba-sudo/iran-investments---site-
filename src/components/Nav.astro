---
import Logo from './Logo.astro';
const path = Astro.url.pathname;
const isHome = path === '/';
const isContent = path.startsWith('/blog');
---
<nav>
  <a class="logo-wrap" href="/" style="display:block;">
    <Logo height="70px" />
  </a>
  <ul class="nav-links" id="navLinks">
    <li><a id="nav-home" href="/" class={isHome ? 'nav-a' : ''}>Home</a></li>
    <li><a id="nav-content" href="/blog/" class={isContent ? 'nav-a' : ''}>Content</a></li>
    <li><a href="/#visionSection" class="vision-link">Vision</a></li>
    <li><a class="nav-cta" href="#" onclick="openModal();return false;">Subscribe Free</a></li>
  </ul>
  <button id="navToggle" onclick="document.getElementById('navLinks').classList.toggle('open')" style="display:none;background:none;border:none;cursor:pointer;width:34px;height:34px;align-items:center;justify-content:center;flex-direction:column;gap:4px;">
    <span style="width:20px;height:2px;background:var(--text);display:block;"></span>
    <span style="width:20px;height:2px;background:var(--text);display:block;"></span>
    <span style="width:20px;height:2px;background:var(--text);display:block;"></span>
  </button>
</nav>

<script>
  const link = document.querySelector('.vision-link');
  link?.addEventListener('click', (e) => {
    if (window.location.pathname === '/') {
      e.preventDefault();
      setTimeout(() => document.getElementById('visionSection')?.scrollIntoView({ behavior: 'smooth' }), 20);
    }
  });
</script>
