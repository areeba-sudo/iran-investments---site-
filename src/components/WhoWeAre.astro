---
import type { HomepageDoc } from '../lib/sanity';

interface Props {
  homepage: HomepageDoc;
}
const { homepage } = Astro.props;
---
<div class="wwa-wrap">
  <div class="wwa-inner">
    <div class="sr-l">
      <span class="section-tag">{homepage.whoTag}</span>
      <h2>{homepage.whoHeading}</h2>
      <p class="tagline">{homepage.whoTagline}</p>
      <p>{homepage.whoBody}</p>
    </div>
    <div class="sr-r">
      <p style="color:rgba(250,249,245,.3);font-size:11px;letter-spacing:1.5px;text-transform:uppercase;font-weight:600;margin-bottom:16px">Who reads us</p>
      <div class="for-grid">
        {homepage.whoReaderCards.map((c) => (
          <div class="for-card"><h4>{c.title}</h4><p>{c.body}</p></div>
        ))}
      </div>
    </div>
  </div>
</div>
