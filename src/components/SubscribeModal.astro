---
import Logo from './Logo.astro';
---
<div class="modal-overlay" id="modalOverlay" onclick="ovClick(event)">
  <div class="modal"><button class="mc" onclick="closeModal()">✕</button>
    <div class="ml" style="margin-left:-8px"><Logo height="58px" /></div>
    <div class="m-frm" id="mFrm"><h2>Get the inside edge on Iran's market — free.</h2><p class="m-sub">Join 10,000+ investors and business leaders receiving our weekly intelligence drop.</p><div><label class="m-lbl" for="mEmail">Email address</label><input class="m-in" type="email" id="mEmail" placeholder="you@example.com" autocomplete="email" onkeydown="if(event.key==='Enter')document.getElementById('bLink').click()"><div class="m-err" id="mErr"></div></div><a class="m-btn" id="bLink" href="#" target="_blank" rel="noopener" onclick="return subClick(this)">Subscribe Free →</a><p class="m-disc">No spam. Unsubscribe anytime.</p></div>
    <div class="m-suc" id="mSuc"><div class="s-ico">✓</div><h3>Almost there!</h3><p>A Beehiiv tab opened with your email pre-filled. Hit <strong>Subscribe</strong> to confirm.</p><button class="m-back" onclick="closeModal()">Back to Site</button></div>
  </div>
</div>
