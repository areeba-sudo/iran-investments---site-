---
import type { HomepageDoc, PostSummary } from '../lib/sanity';
import PostCard from './PostCard.astro';

interface Props {
  homepage: HomepageDoc;
  posts: PostSummary[];
}
const { homepage, posts } = Astro.props;
---
<div class="blog-wrap">
  <div class="blog-inner">
    <div class="blog-hd">
      <div class="blog-hd-left">
        <div class="section-tag">{homepage.blogTag}</div>
        <h2>{homepage.blogHeading}</h2>
      </div>
      <div class="sl-btns">
        <button class="sl-btn" onclick="hSlide(-1)">←</button>
        <button class="sl-btn" onclick="hSlide(1)">→</button>
      </div>
    </div>
    <div class="sl-outer">
      <div class="sl-track" id="homeTrack">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
    </div>
  </div>
</div>
