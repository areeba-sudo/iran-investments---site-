---
import { homepage } from '../data/homepage';
const { hero } = homepage;
---
<section class="hero-section" id="heroSection">
  <div class="hero-text">
    <div class="pill">{hero.pill}</div>
    <h1 set:html={hero.headline} />
    <p class="sub">{hero.subheadline}</p>
    <div class="hero-btns">
      <button class="btn-primary will-mag" onclick="openModal()">Join <span id="ctrNum">0</span>+ Readers</button>
      <button class="btn-ghost will-mag" onclick="location.href='/blog/'">Explore Content ↓</button>
    </div>
  </div>
  <div class="hero-right" style="position:relative;">
    <canvas id="hero3dCanvas" style="width:100%;height:480px;border-radius:16px;display:block;"></canvas>
    <div id="globePopup" style="position:absolute;background:#ffffff;border:1px solid #e2ddd5;border-radius:12px;padding:12px 18px;min-width:180px;max-width:260px;box-shadow:0 6px 24px rgba(0,0,0,0.08);pointer-events:none;opacity:0;transition:opacity 0.7s ease;font-family:'Georgia',serif;z-index:10;">
      <div style="display:flex;align-items:center;gap:8px;">
        <span id="globePopupDot" style="width:8px;height:8px;border-radius:50%;background:#eb5e3e;flex-shrink:0;animation:pdot 2s ease-in-out infinite;"></span>
        <span id="globePopupText" style="font-size:13px;color:#1a1a1a;font-weight:600;line-height:1.4;">Iran</span>
      </div>
      <div style="font-size:11px;color:#aaa;margin-top:3px;padding-left:16px;letter-spacing:0.03em;">Middle East · 32°N 53°E</div>
    </div>
  </div>
</section>
