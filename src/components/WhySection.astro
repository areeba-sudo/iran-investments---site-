---
import type { HomepageDoc } from '../lib/sanity';

interface Props {
  homepage: HomepageDoc;
}
const { homepage } = Astro.props;
const pillClasses = ['wi-pill-green', 'wi-pill-red', 'wi-pill-purple'];
const icons = [
  `<svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="24" cy="24" r="13" stroke="#bdd5a6" stroke-width="1.5"/>
    <path d="M34 34 L46 46" stroke="#eb5e3e" stroke-width="2.5" stroke-linecap="round"/>
    <path d="M18 24 H30" stroke="#bdd5a6" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M24 18 V30" stroke="#bdd5a6" stroke-width="1.5" stroke-linecap="round"/>
    <circle cx="24" cy="24" r="4" fill="rgba(189,213,166,0.2)"/>
  </svg>`,
  `<svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
    <line x1="28" y1="6" x2="28" y2="50" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
    <line x1="10" y1="20" x2="46" y2="20" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
    <path d="M10 20 L4 36 C4 42 20 42 16 36 Z" stroke="#eb5e3e" stroke-width="1.5" fill="rgba(235,94,62,0.1)"/>
    <path d="M46 20 L40 36 C40 42 52 42 52 36 Z" stroke="#bdd5a6" stroke-width="1.5" fill="rgba(189,213,166,0.1)"/>
    <circle cx="28" cy="20" r="4" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
  </svg>`,
  `<svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg">
    <circle cx="28" cy="28" r="20" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
    <circle cx="28" cy="28" r="13" stroke="#bdd5a6" stroke-width="1.5"/>
    <circle cx="28" cy="28" r="5" fill="#eb5e3e"/>
    <path d="M28 8 V15" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M28 41 V48" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M8 28 H15" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M41 28 H48" stroke="rgba(255,255,255,0.2)" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
];
---
<section class="why-section" id="whySection">
  <div id="why3d"></div>
  <div class="why-inner">
    <div class="why-header sr">
      <div class="section-tag">{homepage.whyTag}</div>
      <h2>{homepage.whyHeading}</h2>
      <p>{homepage.whyBody}</p>
    </div>
    <div class="why-list">
      {homepage.whyItems.map((item, i) => (
        <div class="why-item sr" style={`transition-delay:.${i + 1}s`}>
          <div class="wi-num">{String(i + 1).padStart(2, '0')}</div>
          <div class="wi-vline"></div>
          <div class="wi-icon" set:html={icons[i]} />
          <div class="wi-body"><h3>{item.title}</h3><p>{item.body}</p></div>
          <div class={`wi-pill ${pillClasses[i]}`}>{item.pillLabel}</div>
        </div>
      ))}
    </div>
  </div>
</section>
