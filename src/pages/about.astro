---
import SiteLayout from '../layouts/SiteLayout.astro';
import SubscribeStrip from '../components/SubscribeStrip.astro';
import { getAllPosts, urlFor } from '../lib/sanity';

const latest = (await getAllPosts()).slice(0, 8);

const readers = [
  { n: '01', t: 'Business Owners', d: 'Expand into new markets with strategic intelligence and regional expertise.' },
  { n: '02', t: 'Entrepreneurs', d: 'Identify first-mover opportunities in an emerging economy.' },
  { n: '03', t: 'HNWIs & Family Wealth', d: 'Diversify portfolios with high-potential alternative market exposure.' },
  { n: '04', t: 'International Businesses', d: 'Structure compliant cross-border operations with confidence.' },
];
const pillars = [
  { n: '01', t: 'Legitimate Intelligence', d: "Verified insight on Iran's business environment, regulations, and opportunities — free from media noise and political bias." },
  { n: '02', t: 'Legal Framework Clarity', d: 'We map every permissible pathway. Know exactly how to engage Iranian markets without crossing any legal lines.' },
  { n: '03', t: 'Actionable Strategy', d: 'Not just what the opportunity is — but how to execute on it. Every piece moves you closer to a real decision.' },
];
---
<SiteLayout
  title="About — Iran Investment"
  description="The story behind Iran Investment: independent, on-the-ground intelligence on the region's most misunderstood market."
>
  <div class="ii-ab">
    <!-- 1 · HERO -->
    <section class="ii-ab-hero">
      <img class="ii-ab-hero-img" src="/about/hero-tehran.jpg" alt="Tehran skyline at night" />
      <div class="ii-ab-hero-grad"></div>
      <div class="ii-ab-hero-inner">
        <div class="ii-ab-masthead"><span></span>Iran Investment · The About Edition · Est. 2026</div>
        <div class="ii-ab-kicker" style="color:#D9BE84;">About Us</div>
        <h1 class="ii-ab-h1">Independent intelligence on the region's most misunderstood market.</h1>
        <p class="ii-ab-hero-lede">The story behind the newsletter repricing the largest untapped market between Europe and India.</p>
      </div>
    </section>

    <!-- 2 · WHO WE ARE -->
    <section class="ii-ab-paper">
      <div class="ii-ab-wrap ii-ab-who">
        <div>
          <div class="ii-ab-kicker" style="color:#B8923D;">Who We Are</div>
          <h2 class="ii-ab-h2 dark">An International Business Development &amp; Consulting Newsletter.</h2>
          <blockquote class="ii-ab-quote">For headlines, hot-takes, and practical content that will help you grab the right opportunities to protect and grow your wealth.</blockquote>
          <p class="ii-ab-body dark">We provide free premium content on Iran and international business development — helping businessmen and investors identify opportunities and execute them in the right, strategic manner.</p>
        </div>
        <figure class="ii-ab-figure">
          <div class="ii-ab-figframe">
            <img src="/about/curvy.jpg" alt="" />
          </div>
          <figcaption>№ 01 — On the ground, ahead of consensus.</figcaption>
        </figure>
      </div>
    </section>

    <!-- 3 · THE INFORMATION GAP -->
    <section class="ii-ab-light">
      <div class="ii-ab-wrap">
        <div class="ii-ab-kicker" style="color:#B8923D;">Why Iran Investment</div>
        <h2 class="ii-ab-h2 dark" style="max-width:820px;">The information gap we exist to close.</h2>
        <p class="ii-ab-body dark" style="max-width:600px;">Iran is one of the most misunderstood emerging markets on the planet. We cut through the noise with verified, on-the-ground intelligence — and map exactly how you can act on it, legally.</p>
        <div class="ii-ab-pillars">
          {pillars.map((p) => (
            <article class="ii-ab-pillar">
              <span class="ii-ab-num">{p.n}</span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 4 · VISION -->
    <section class="ii-ab-vision">
      <img class="ii-ab-vision-img" src="/about/swirl.jpg" alt="" />
      <div class="ii-ab-vision-grad"></div>
      <div class="ii-ab-wrap ii-ab-vision-inner">
        <div class="ii-ab-kicker" style="color:#D9BE84;">Our Vision</div>
        <p class="ii-ab-vision-q">Nobody should stay blinded by geopolitical chaos — because right behind the chaos are opportunities that can make you rich.</p>
      </div>
    </section>

    <!-- 5 · WHO READS US -->
    <section class="ii-ab-paper">
      <div class="ii-ab-wrap">
        <div class="ii-ab-kicker" style="color:#B8923D;">Who Reads Us</div>
        <h2 class="ii-ab-h2 dark" style="max-width:640px;">Built for the people who move first.</h2>
        <div class="ii-ab-readers">
          {readers.map((r, i) => (
            <article class="ii-ab-reader" style={`background-image:linear-gradient(160deg,rgba(251,249,243,.86),rgba(244,239,228,.93)),url('/about/${['marble','ribs','curvy','marble'][i]}.jpg');`}>
              <span class="ii-ab-num light">{r.n}</span>
              <h3>{r.t}</h3>
              <p>{r.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- 6 · LATEST CONTENT SLIDER -->
    {latest.length > 0 && (
      <section class="ii-ab-light">
        <div class="ii-ab-wrap">
          <div class="ii-ab-slide-head">
            <div>
              <div class="ii-ab-kicker" style="color:#B8923D;">The Latest</div>
              <h2 class="ii-ab-h2 dark" style="max-width:640px;">Content that helps you identify the right opportunities.</h2>
            </div>
            <div class="ii-ab-arrows">
              <button class="ii-ab-arrow" data-scroll-dir="-1" aria-label="Scroll left"><svg width="16" height="12" viewBox="0 0 17 12" fill="none"><path d="M17 6H2M6 1L1 6l5 5" stroke="#0B3B36" stroke-width="1.5"></path></svg></button>
              <button class="ii-ab-arrow" data-scroll-dir="1" aria-label="Scroll right"><svg width="16" height="12" viewBox="0 0 17 12" fill="none"><path d="M0 6h15M11 1l5 5-5 5" stroke="#0B3B36" stroke-width="1.5"></path></svg></button>
            </div>
          </div>
          <div class="ii-ab-scroller" data-scroller>
            {latest.map((p) => (
              <a class="ii-ab-slide" href={`/blog/${p.slug}/`}>
                <div class="ii-ab-slide-img">
                  {p.coverImage && <img src={urlFor(p.coverImage).width(560).height(560).auto('format').url()} alt={p.title} loading="lazy" />}
                </div>
                <div class="ii-ab-slide-sec">{p.section?.title || 'Article'}</div>
                <h3 class="ii-ab-slide-title">{p.title}</h3>
              </a>
            ))}
          </div>
          <a href="/weekly-insights/" class="ii-ab-btn">Read more<svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M0 5h14M10 1l4 4-4 4" stroke="currentColor" stroke-width="1.5"></path></svg></a>
        </div>
      </section>
    )}

    <SubscribeStrip />
  </div>
</SiteLayout>

<style is:global>
  .ii-ab { background: #0b0b0b; }
  .ii-ab-wrap { max-width: 1280px; margin: 0 auto; padding: 0 40px; }
  .ii-ab-kicker { font-family: 'Inter'; font-size: 11px; font-weight: 700; letter-spacing: .26em; text-transform: uppercase; margin-bottom: 20px; }
  .ii-ab-h1 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: clamp(38px, 6vw, 68px); line-height: 1.04; letter-spacing: -.015em; color: #F7F3EA; margin-bottom: 20px; max-width: 15ch; text-wrap: balance; }
  .ii-ab-h2 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: clamp(28px, 4vw, 42px); line-height: 1.1; color: #F7F3EA; margin-bottom: 22px; text-wrap: balance; }
  .ii-ab-h2.dark { color: #0B3B36; }
  .ii-ab-body { font-size: 16px; line-height: 1.75; color: rgba(247,243,234,.66); }
  .ii-ab-body.dark { color: #5B584F; }

  /* HERO */
  .ii-ab-hero { position: relative; min-height: 90vh; display: flex; align-items: flex-end; overflow: hidden; background: #0b0b0b; }
  .ii-ab-hero-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; object-position: center 42%; }
  .ii-ab-hero-grad { position: absolute; inset: 0; background: linear-gradient(180deg, rgba(11,11,11,.55) 0%, rgba(11,11,11,.15) 32%, rgba(11,11,11,.72) 76%, #0b0b0b 100%); }
  .ii-ab-hero-inner { position: relative; width: 100%; max-width: 1280px; margin: 0 auto; padding: 0 40px 92px; }
  .ii-ab-masthead { display: flex; align-items: center; gap: 14px; font-family: 'Inter'; font-size: 10.5px; font-weight: 600; letter-spacing: .28em; text-transform: uppercase; color: rgba(247,243,234,.6); margin-bottom: 30px; padding-bottom: 18px; border-bottom: 1px solid rgba(247,243,234,.16); }
  .ii-ab-masthead span { width: 34px; height: 1px; background: #D9BE84; }
  .ii-ab-hero-lede { font-size: 17px; line-height: 1.6; color: rgba(247,243,234,.7); max-width: 520px; margin-top: 4px; }

  /* DARK / LIGHT sections */
  .ii-ab-dark { background: #0b0b0b; padding: 100px 0; }
  .ii-ab-light { background: #F7F3EA; padding: 100px 0; border-top: 1px solid #E7DFCD; }
  .ii-ab-paper { background: #F7F3EA; padding: 100px 0; }

  /* WHO WE ARE */
  .ii-ab-who { display: grid; grid-template-columns: 1.25fr 1fr; gap: 70px; align-items: center; }
  .ii-ab-quote { font-family: 'Playfair Display', serif; font-style: italic; font-weight: 500; font-size: 25px; line-height: 1.45; color: #9A7A31; margin: 0 0 26px; padding-left: 24px; border-left: 2px solid rgba(184,146,61,.5); }
  .ii-ab-figure { margin: 0; }
  .ii-ab-figframe { position: relative; overflow: hidden; border: 1px solid #E4DCC8; cursor: pointer; }
  .ii-ab-figframe img { display: block; width: 100%; aspect-ratio: 4/5; object-fit: cover; filter: grayscale(1) contrast(1.05); transition: filter .5s ease, transform .6s cubic-bezier(.22,1,.36,1); }
  .ii-ab-figframe::after { content: ""; position: absolute; inset: 0; background: #2f8a5f; mix-blend-mode: color; opacity: 0; transition: opacity .5s ease; pointer-events: none; }
  .ii-ab-figframe:hover img { transform: scale(1.04); }
  .ii-ab-figframe:hover::after { opacity: 1; }
  .ii-ab-figure figcaption { font-family: 'Inter'; font-size: 10.5px; letter-spacing: .16em; text-transform: uppercase; color: #8A8676; margin-top: 14px; }

  /* PILLARS (info gap) — editorial, no boxes */
  .ii-ab-pillars { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0; margin-top: 56px; }
  .ii-ab-pillar { padding: 30px 34px 8px 0; border-top: 1px solid #CDC2A8; }
  .ii-ab-pillar + .ii-ab-pillar { padding-left: 34px; border-left: 1px solid #CDC2A8; }
  .ii-ab-num { font-family: 'Playfair Display', serif; font-size: 34px; font-weight: 500; color: #B8923D; display: block; margin-bottom: 18px; }
  .ii-ab-num.light { color: #B8923D; }
  .ii-ab-pillar h3 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 22px; color: #0B3B36; margin-bottom: 12px; }
  .ii-ab-pillar p { font-size: 14px; line-height: 1.65; color: #5B584F; }

  /* VISION (colour) */
  .ii-ab-vision { position: relative; overflow: hidden; background: #05100f; padding: 130px 0; }
  .ii-ab-vision-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: .8; }
  .ii-ab-vision-grad { position: absolute; inset: 0; background: radial-gradient(120% 90% at 50% 40%, rgba(5,16,15,.35), rgba(5,16,15,.82)); }
  .ii-ab-vision-inner { position: relative; text-align: center; }
  .ii-ab-vision-q { font-family: 'Playfair Display', serif; font-weight: 600; font-size: clamp(28px, 4.4vw, 50px); line-height: 1.18; color: #F7F3EA; max-width: 17ch; margin: 8px auto 0; text-wrap: balance; text-shadow: 0 2px 30px rgba(0,0,0,.4); }

  /* WHO READS US — light editorial tiles with faint B&W texture */
  .ii-ab-readers { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; margin-top: 52px; }
  .ii-ab-reader { position: relative; overflow: hidden; padding: 34px 32px 30px; min-height: 200px; display: flex; flex-direction: column; background-size: cover; background-position: center; border: 1px solid #E4DCC8; transition: transform .4s cubic-bezier(.22,1,.36,1), border-color .4s, box-shadow .4s; }
  .ii-ab-reader:hover { transform: translateY(-4px); border-color: #B8923D; box-shadow: 0 18px 40px rgba(28,28,26,.10); }
  .ii-ab-reader h3 { font-family: 'Playfair Display', serif; font-weight: 700; font-size: 21px; color: #0B3B36; margin-bottom: 10px; }
  .ii-ab-reader p { font-size: 13.5px; line-height: 1.6; color: #5B584F; max-width: 30ch; }

  /* LATEST SLIDER */
  .ii-ab-slide-head { display: flex; align-items: flex-end; justify-content: space-between; gap: 24px; margin-bottom: 40px; }
  .ii-ab-arrows { display: flex; gap: 10px; flex-shrink: 0; }
  .ii-ab-arrow { width: 46px; height: 46px; border-radius: 50%; border: 1px solid #C9BF9F; background: none; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .25s, border-color .25s; }
  .ii-ab-arrow:hover { background: #0B3B36; border-color: #0B3B36; }
  .ii-ab-arrow:hover svg path { stroke: #F7F3EA; }
  .ii-ab-scroller { display: grid; grid-auto-flow: column; grid-auto-columns: 300px; gap: 22px; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; padding-bottom: 6px; }
  .ii-ab-scroller::-webkit-scrollbar { display: none; }
  .ii-ab-slide { scroll-snap-align: start; text-decoration: none; display: block; }
  .ii-ab-slide-img { aspect-ratio: 1/1; overflow: hidden; background: #0B3B36; margin-bottom: 16px; }
  .ii-ab-slide-img img { width: 100%; height: 100%; object-fit: cover; filter: grayscale(1) contrast(1.03); transition: filter .5s ease, transform .6s ease; }
  .ii-ab-slide:hover .ii-ab-slide-img img { filter: grayscale(0); transform: scale(1.04); }
  .ii-ab-slide-sec { font-size: 10px; font-weight: 700; letter-spacing: .2em; text-transform: uppercase; color: #B8923D; margin-bottom: 8px; }
  .ii-ab-slide-title { font-family: 'Playfair Display', serif; font-weight: 600; font-size: 19px; line-height: 1.28; color: #1C1C1A; }
  .ii-ab-btn { display: inline-flex; align-items: center; gap: 10px; margin-top: 44px; background: #0B3B36; color: #F7F3EA; padding: 15px 30px; border-radius: 3px; font-family: 'Inter'; font-weight: 700; font-size: 12px; letter-spacing: .1em; text-transform: uppercase; text-decoration: none; transition: gap .25s, background .25s; }
  .ii-ab-btn:hover { gap: 15px; background: #0f5049; }

  @media (max-width: 900px) {
    .ii-ab-who { grid-template-columns: 1fr; gap: 40px; }
    .ii-ab-figure { max-width: 380px; }
    .ii-ab-pillars { grid-template-columns: 1fr; }
    .ii-ab-pillar { border-left: none !important; padding: 26px 0 8px !important; }
    .ii-ab-readers { grid-template-columns: 1fr; }
  }
  @media (max-width: 680px) {
    .ii-ab-dark, .ii-ab-light { padding: 64px 0; }
    .ii-ab-vision { padding: 90px 0; }
    .ii-ab-wrap, .ii-ab-hero-inner { padding-left: 24px; padding-right: 24px; }
    .ii-ab-hero-inner { padding-bottom: 60px; }
    .ii-ab-slide-head { flex-direction: column; align-items: flex-start; }
    .ii-ab-scroller { grid-auto-columns: 260px; }
  }
</style>
