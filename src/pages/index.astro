---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Ticker from '../components/Ticker.astro';
import WhySection from '../components/WhySection.astro';
import StatsSection from '../components/StatsSection.astro';
import ScrollJourney from '../components/ScrollJourney.astro';
import WhoWeAre from '../components/WhoWeAre.astro';
import Vision from '../components/Vision.astro';
import BlogSlider from '../components/BlogSlider.astro';
import Banner from '../components/Banner.astro';
import { getHomepage, getAllPosts } from '../lib/sanity';

const homepage = await getHomepage();
const posts = await getAllPosts();
---
<BaseLayout title={homepage.seo?.metaTitle || homepage.heroHeadline} description={homepage.seo?.metaDescription || homepage.heroSubheadline}>
  <script slot="head" src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>

  <Hero homepage={homepage} />
  <Ticker />
  <WhySection homepage={homepage} />
  <StatsSection homepage={homepage} />
  <ScrollJourney />
  <WhoWeAre homepage={homepage} />
  <Vision homepage={homepage} />
  <BlogSlider homepage={homepage} posts={posts} />
  <Banner homepage={homepage} />

  <script>
    import { initHome } from '../scripts/home.js';
    document.addEventListener('DOMContentLoaded', () => {
      initHome();
    });
  </script>
</BaseLayout>
