---
// Homepage — magazine design from the Claude Design handoff. The hero carousel,
// secondary stories and market snapshot are CMS-wired (editor-curated in Sanity
// with a fallback to the latest articles); the Explore Sectors cards + copy are
// design content. Every article link resolves to a /blog/[slug] inner page.
import SiteLayout from '../layouts/SiteLayout.astro';
import { getWeeklyEditions, getMarketSnapshot, getHomepage, getAllPosts, urlFor, type MarketMetric } from '../lib/sanity';

// The "Featured Insight / Weekly Column" block is a carousel of Weekly Editions.
const [weeklyEditions, market, home, allPosts] = await Promise.all([
  getWeeklyEditions(),
  getMarketSnapshot(),
  getHomepage(),
  getAllPosts(),
]);

// Hero carousel: editor-curated slides in the CMS, with a fallback to the latest
// articles so it is never empty and every "Read the Full Story" link resolves.
const curatedHero = (home?.heroSlides || [])
  .map((s) => ({ post: s.article, kicker: s.kickerOverride }))
  .filter((s) => s.post);
const heroSlides = (
  curatedHero.length ? curatedHero : allPosts.slice(0, 3).map((p) => ({ post: p, kicker: undefined }))
).slice(0, 3);

// Secondary stories strip: curated pair → fallback to the next latest articles.
const heroIds = new Set(heroSlides.map((s) => s.post._id));
const curatedSecondary = (home?.secondaryStories || []).filter(Boolean);
const secondaryStories = (
  curatedSecondary.length ? curatedSecondary : allPosts.filter((p) => !heroIds.has(p._id)).slice(0, 2)
).slice(0, 2);
const marketDate = market.asOf
  ? new Date(market.asOf).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  : '';
function arrowFor(direction?: MarketMetric['direction']) {
  const green = '#1F7A4D';
  const red = '#C0442E';
  if (direction === 'up') return { d: 'M4 0l4 8H0z', color: green };
  if (direction === 'down-good') return { d: 'M4 8L0 0h8z', color: green };
  return { d: 'M4 8L0 0h8z', color: red }; // down-bad
}
---
<SiteLayout
  title="Iran Investment — Economics, Markets & Opportunities"
  description="Institutional-grade editorial intelligence on Iran's economy, markets, and the opportunities inside them."
>
  <div id="ii-home" style="position:relative;background:#F7F3EA;">

    <!-- HERO CAROUSEL -->
    <section data-screen-label="Hero carousel" style="position:relative;height:82vh;min-height:560px;overflow:hidden;background:#0B3B36;">
      <div id="ii-carousel" style="position:absolute;inset:0;">
        {heroSlides.map((s, i) => {
          const p = s.post;
          const img = p.coverImage ? urlFor(p.coverImage).width(2000).auto('format').url() : '';
          const kick = s.kicker || p.kicker || p.section?.title || 'Featured';
          return (
            <div class={`ii-slide${i === 0 ? ' on' : ''}`} data-slide={i}>
              {img && <img class="ii-slide-img" src={img} alt={p.title} style="object-position:center 45%;filter:saturate(.72);" />}
              <div style="position:absolute;inset:0;background:linear-gradient(180deg,rgba(11,59,54,.32) 0%,rgba(11,59,54,.55) 45%,rgba(11,59,54,.94) 100%);"></div>
              <div style="position:absolute;inset:0;background:linear-gradient(105deg,rgba(11,59,54,.6) 0%,rgba(11,59,54,.06) 60%);mix-blend-mode:multiply;"></div>
              <div style="position:relative;height:100%;max-width:1280px;margin:0 auto;padding:0 40px;display:flex;align-items:flex-end;">
                <div class="ii-slide-copy" style="max-width:820px;padding-bottom:118px;">
                  <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:22px;"><span style="width:26px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:#D9BE84;">{kick}</span></div>
                  <h1 style="font-family:'Playfair Display',serif;font-weight:700;font-size:58px;line-height:1.07;letter-spacing:-.01em;color:#F7F3EA;margin-bottom:20px;text-wrap:balance;">{p.title}</h1>
                  {p.excerpt && <p style="font-size:16.5px;line-height:1.65;color:rgba(247,243,234,.74);max-width:560px;margin-bottom:32px;">{p.excerpt}</p>}
                  <a href={`/blog/${p.slug}/`} class="ii-herocta">Read the Full Story<svg width="17" height="11" viewBox="0 0 17 11" fill="none"><path d="M0 5.5h15M11 1l4.5 4.5L11 10" stroke="#1C1C1A" stroke-width="1.5"></path></svg></a>
                </div>
              </div>
            </div>
          );
        })}
      </div>

      <!-- carousel controls -->
      <div style="position:absolute;left:0;right:0;bottom:44px;z-index:10;">
        <div style="max-width:1280px;margin:0 auto;padding:0 40px;display:flex;align-items:center;justify-content:space-between;gap:24px;">
          <div id="ii-dots" style="display:flex;align-items:center;gap:12px;">
            {heroSlides.map((_, i) => (
              <button class={`ii-dot${i === 0 ? ' on' : ''}`} data-go={i} aria-label={`Go to slide ${i + 1}`}><span></span></button>
            ))}
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <button class="ii-cbtn" data-dir="-1" aria-label="Previous"><svg width="17" height="12" viewBox="0 0 17 12" fill="none"><path d="M17 6H2M6 1L1 6l5 5" stroke="#D9BE84" stroke-width="1.5"></path></svg></button>
            <button class="ii-cbtn" data-dir="1" aria-label="Next"><svg width="17" height="12" viewBox="0 0 17 12" fill="none"><path d="M0 6h15M11 1l5 5-5 5" stroke="#D9BE84" stroke-width="1.5"></path></svg></button>
          </div>
        </div>
      </div>

      <div style="position:absolute;left:40px;bottom:110px;display:flex;align-items:center;gap:12px;color:rgba(247,243,234,.5);z-index:10;">
        <div style="animation:ii_scrollCue 2.2s ease-in-out infinite;"><svg width="13" height="20" viewBox="0 0 13 20" fill="none"><rect x="1" y="1" width="11" height="18" rx="5.5" stroke="rgba(247,243,234,.5)" stroke-width="1.2"></rect><circle cx="6.5" cy="6" r="1.6" fill="rgba(247,243,234,.7)"></circle></svg></div>
      </div>
    </section>

    <!-- SECONDARY STORIES STRIP -->
    <section data-screen-label="Secondary stories" style="background:#F7F3EA;border-bottom:1px solid #E4DCC8;">
      <div class="ii-secondary-grid" style="max-width:1280px;margin:0 auto;padding:0 40px;display:grid;grid-template-columns:1fr 1fr;">
        {secondaryStories.map((p, i) => (
          <a
            href={`/blog/${p.slug}/`}
            data-reveal
            data-delay={i === 1 ? '90' : undefined}
            class="ii-secondary-item"
            style={`text-decoration:none;padding:${i === 0 ? '30px 44px 30px 0' : '30px 0 30px 44px'};${i === 0 ? 'border-right:1px solid #E4DCC8;' : ''}display:block;`}
          >
            <div style="font-size:10px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#B8923D;margin-bottom:12px;">{p.section?.title || 'Article'}</div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;gap:24px;">
              <h3 style="font-family:'Playfair Display',serif;font-weight:600;font-size:21px;line-height:1.28;color:#1C1C1A;max-width:420px;">{p.title}</h3>
              {p.readTime && <span style="font-size:11px;font-weight:500;letter-spacing:.05em;color:#5B584F;white-space:nowrap;">{p.readTime}</span>}
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- SUBSCRIPTION STRIP (sleek) -->
    <section data-screen-label="Subscribe strip" style="background:#0B3B36;position:relative;overflow:hidden;">
      <div class="ii-substrip" style="max-width:1280px;margin:0 auto;padding:48px 40px;display:flex;align-items:center;justify-content:space-between;gap:56px;flex-wrap:wrap;position:relative;">
        <div style="max-width:440px;">
          <div style="font-family:'Playfair Display',serif;font-weight:600;font-size:28px;color:#F7F3EA;line-height:1.12;">Weekly insights, delivered.</div>
          <div style="font-size:14px;color:rgba(247,243,234,.6);margin-top:9px;">Join investors and executives who read Iran Investment every week.</div>
        </div>
        <form id="ii-sub-form" style="flex:1;min-width:340px;max-width:480px;">
          <div class="ii-sleek" id="ii-sleek-wrap">
            <input id="ii-sub-input" type="email" placeholder="Enter your email address" />
            <button type="submit"><span id="ii-sub-label">Subscribe</span><svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M0 5h14M10 1l4 4-4 4" stroke="#D9BE84" stroke-width="1.5"></path></svg></button>
          </div>
          <div style="font-size:11px;color:rgba(247,243,234,.4);margin-top:11px;letter-spacing:.02em;">No spam. Unsubscribe anytime.</div>
        </form>
      </div>
    </section>

    <!-- MARKET SNAPSHOT -->
    <section data-screen-label="Market snapshot" style="background:#FBF9F3;border-bottom:1px solid #E4DCC8;">
      <div data-market-ticker style="max-width:1280px;margin:0 auto;padding:0 40px;display:flex;align-items:stretch;overflow-x:auto;">
        <div style="display:flex;align-items:center;padding:20px 28px 20px 0;border-right:1px solid #E4DCC8;flex-shrink:0;">
          <span style="font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#5B584F;line-height:1.4;">Market<br />Snapshot<br /><span style="color:#B8923D;" data-market-date>{marketDate}</span></span>
        </div>
        <div style="flex:1;display:flex;align-items:center;justify-content:space-between;flex-wrap:nowrap;">
          {market.metrics.map((m, i) => {
            const last = i === market.metrics.length - 1;
            const a = arrowFor(m.direction);
            const key = m.liveSource && m.liveSource !== 'manual' ? m.liveSource : undefined;
            return (
              <div
                data-metric-key={key}
                style={`padding:${last ? '20px 0 20px 26px' : '20px 26px'};flex:1;min-width:150px;${last ? '' : 'border-right:1px solid #E4DCC8;'}`}
              >
                <div style="font-size:10px;font-weight:600;letter-spacing:.12em;text-transform:uppercase;color:#5B584F;margin-bottom:8px;">{m.label}</div>
                <div style="display:flex;align-items:baseline;gap:7px;">
                  <span data-metric-value style="font-family:'Playfair Display',serif;font-weight:700;font-size:26px;color:#1C1C1A;">{m.value}</span>
                  {m.change && (
                    <span data-metric-change style={`display:inline-flex;align-items:center;gap:2px;font-size:11px;font-weight:600;color:${a.color};`}>
                      <svg width="8" height="8" viewBox="0 0 8 8"><path data-metric-arrow d={a.d} fill={a.color}></path></svg><span data-metric-num>{m.change}</span>
                    </span>
                  )}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- PREMIUM CONTENT CALLOUT -->
    <section data-screen-label="Premium download" style="background:#F7F3EA;padding:72px 0;">
      <div style="max-width:1280px;margin:0 auto;padding:0 40px;">
        <div data-reveal style="position:relative;overflow:hidden;border-radius:6px;background:linear-gradient(120deg,#0B3B36 0%,#0F5049 55%,#0B3B36 100%);box-shadow:0 30px 70px rgba(11,59,54,.28);">
          <div style="position:absolute;width:340px;height:340px;top:-120px;right:8%;border-radius:50%;background:radial-gradient(circle,rgba(217,190,132,.3),transparent 68%);filter:blur(30px);pointer-events:none;"></div>
          <div class="ii-premium-grid" style="position:relative;display:grid;grid-template-columns:1.5fr 1fr;gap:48px;align-items:center;padding:52px 56px;">
            <div>
              <div style="display:inline-flex;align-items:center;gap:9px;background:rgba(217,190,132,.14);border:1px solid rgba(217,190,132,.4);padding:7px 15px;border-radius:100px;margin-bottom:22px;">
                <span style="font-size:10.5px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#D9BE84;">Premium Guide · Free</span>
              </div>
              <h2 style="font-family:'Playfair Display',serif;font-weight:700;font-size:38px;line-height:1.12;color:#F7F3EA;margin-bottom:16px;text-wrap:balance;">How to legally structure your investment in Iran.</h2>
              <p style="font-size:15.5px;line-height:1.68;color:rgba(247,243,234,.72);max-width:460px;margin-bottom:30px;">A 42-page practitioner's guide to entities, free-zone incentives, sanctions-compliant banking channels, and repatriation — sent straight to your inbox.</p>
              <div style="display:flex;align-items:center;gap:26px;flex-wrap:wrap;">
                <button class="ii-getbtn ii-open-modal" data-modal="guide"><span class="sheen"></span>Get it now
                  <svg width="17" height="11" viewBox="0 0 17 11" fill="none"><path d="M0 5.5h15M11 1l4.5 4.5L11 10" stroke="#0B3B36" stroke-width="1.6"></path></svg>
                </button>
                <div style="display:flex;align-items:center;gap:9px;color:rgba(247,243,234,.55);font-size:12.5px;">
                  Downloaded by 3,400+ investors
                </div>
              </div>
            </div>
            <div style="justify-self:center;position:relative;">
              <div style="position:relative;width:210px;height:280px;border-radius:4px;background:linear-gradient(160deg,#124b44,#0B3B36);box-shadow:0 24px 50px rgba(0,0,0,.45);border:1px solid rgba(217,190,132,.35);transform:rotate(3deg);overflow:hidden;padding:26px 22px;display:flex;flex-direction:column;justify-content:space-between;">
                <div style="position:absolute;left:0;top:0;bottom:0;width:5px;background:#B8923D;"></div>
                <div>
                  <div style="font-size:8px;font-weight:700;letter-spacing:.24em;text-transform:uppercase;color:#D9BE84;margin-bottom:14px;">Iran Investment</div>
                  <svg width="34" height="34" viewBox="0 0 34 34" fill="none" style="margin-bottom:16px;"><rect x="8" y="8" width="18" height="18" stroke="#D9BE84" stroke-width="1"></rect><rect x="8" y="8" width="18" height="18" transform="rotate(45 17 17)" stroke="#D9BE84" stroke-width="1"></rect></svg>
                  <div style="font-family:'Playfair Display',serif;font-weight:700;font-size:20px;line-height:1.2;color:#F7F3EA;">Legal Structuring Handbook</div>
                </div>
                <div style="font-size:8.5px;letter-spacing:.16em;text-transform:uppercase;color:rgba(247,243,234,.5);">2026 Edition · 42 pp</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- EXPLORE SECTORS -->
    <section data-screen-label="Explore sectors" style="background:#F7F3EA;padding:96px 0;">
      <div style="max-width:1280px;margin:0 auto;padding:0 40px;">
        <div data-reveal style="max-width:640px;margin-bottom:56px;">
          <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;"><span style="width:26px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:#B8923D;">Explore Sectors</span></div>
          <h2 style="font-family:'Playfair Display',serif;font-weight:700;font-size:44px;line-height:1.08;color:#0B3B36;margin-bottom:16px;">Where Iranian capital is moving next.</h2>
          <p style="font-size:16px;line-height:1.65;color:#5B584F;">Independent, ground-level intelligence on the sectors defining the next decade of Iranian growth.</p>
        </div>
        <div class="ii-sector-grid" style="display:grid;grid-template-columns:repeat(4,1fr);gap:24px;">
          <div class="ii-scard" data-reveal>
            <img class="ii-scard-bw" src="/sectors/bw-petrochemicals.jpg" alt="" loading="lazy" />
            <img class="ii-scard-img" src="/design/sector-petrochemicals.jpg" alt="Petrochemical plant at night" loading="lazy" />
            <div class="ii-scard-basetint"></div>
            <div class="ii-scard-tint"></div>
            <div class="ii-scard-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;">
                <div class="ii-badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M13 2 4 14h7l-1 8 9-12h-7z" stroke-width="1.4" stroke-linejoin="round"></path></svg></div>
                <span class="ii-scard-num">01</span>
              </div>
              <div>
                <h3 class="ii-scard-title">Petrochemicals</h3>
                <p class="ii-scard-desc">The world's second-largest gas reserves, newly open to partnership.</p>
                <a href="/section/sectors/" class="ii-scard-cta">Read More<svg width="15" height="9" viewBox="0 0 15 9" fill="none"><path d="M0 4.5h12M9 1l3.5 3.5L9 8" stroke="#F7F3EA" stroke-width="1.4"></path></svg></a>
              </div>
            </div>
          </div>
          <div class="ii-scard" data-reveal data-delay="80">
            <img class="ii-scard-bw" src="/sectors/bw-pharma.jpg" alt="" loading="lazy" />
            <img class="ii-scard-img" src="/design/sector-pharma.jpg" alt="Cleanroom pharmaceutical worker" loading="lazy" />
            <div class="ii-scard-basetint"></div>
            <div class="ii-scard-tint"></div>
            <div class="ii-scard-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;">
                <div class="ii-badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 3v18M3 12h18" stroke-width="1.6" stroke-linecap="round"></path><circle cx="12" cy="12" r="9.5" stroke-width="1.2"></circle></svg></div>
                <span class="ii-scard-num">02</span>
              </div>
              <div>
                <h3 class="ii-scard-title">Pharmaceuticals</h3>
                <p class="ii-scard-desc">A $4B+ industry with an open gap in the global supply chain.</p>
                <a href="/section/sectors/" class="ii-scard-cta">Read More<svg width="15" height="9" viewBox="0 0 15 9" fill="none"><path d="M0 4.5h12M9 1l3.5 3.5L9 8" stroke="#F7F3EA" stroke-width="1.4"></path></svg></a>
              </div>
            </div>
          </div>
          <div class="ii-scard" data-reveal data-delay="160">
            <img class="ii-scard-bw" src="/sectors/bw-agriculture.jpg" alt="" loading="lazy" />
            <img class="ii-scard-img" src="/design/sector-agriculture.jpg" alt="Saffron harvest" loading="lazy" />
            <div class="ii-scard-basetint"></div>
            <div class="ii-scard-tint"></div>
            <div class="ii-scard-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;">
                <div class="ii-badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M12 21c0-6 4-10 8-11-1 6-4 10-8 11zM12 21c0-6-4-10-8-11 1 6 4 10 8 11zM12 21V8" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path></svg></div>
                <span class="ii-scard-num">03</span>
              </div>
              <div>
                <h3 class="ii-scard-title">Agriculture &amp; Food</h3>
                <p class="ii-scard-desc">37 million hectares of significantly underutilised arable capacity.</p>
                <a href="/section/sectors/" class="ii-scard-cta">Read More<svg width="15" height="9" viewBox="0 0 15 9" fill="none"><path d="M0 4.5h12M9 1l3.5 3.5L9 8" stroke="#F7F3EA" stroke-width="1.4"></path></svg></a>
              </div>
            </div>
          </div>
          <div class="ii-scard" data-reveal data-delay="240">
            <img class="ii-scard-bw" src="/sectors/bw-ftz.jpg" alt="" loading="lazy" />
            <img class="ii-scard-img" src="/design/sector-ftz.jpg" alt="Free trade zone port" loading="lazy" />
            <div class="ii-scard-basetint"></div>
            <div class="ii-scard-tint"></div>
            <div class="ii-scard-body">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;">
                <div class="ii-badge"><svg width="24" height="24" viewBox="0 0 24 24" fill="none"><path d="M4 20V9l8-5 8 5v11" stroke-width="1.4" stroke-linejoin="round"></path><path d="M4 20h16M9 20v-6h6v6" stroke-width="1.4" stroke-linejoin="round"></path></svg></div>
                <span class="ii-scard-num">04</span>
              </div>
              <div>
                <h3 class="ii-scard-title">Free Trade Zones</h3>
                <p class="ii-scard-desc">Kish, Qeshm and Aras — the strongest legal corridors into the market.</p>
                <a href="/section/sectors/" class="ii-scard-cta">Read More<svg width="15" height="9" viewBox="0 0 15 9" fill="none"><path d="M0 4.5h12M9 1l3.5 3.5L9 8" stroke="#F7F3EA" stroke-width="1.4"></path></svg></a>
              </div>
            </div>
          </div>
        </div>
        <div data-reveal style="margin-top:40px;">
          <a href="/section/sectors/" class="ii-viewall" style="display:inline-flex;align-items:center;gap:9px;font-size:12px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:#0B3B36;text-decoration:none;transition:gap .25s;">View All Sectors
            <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M0 5h14M10 1l4 4-4 4" stroke="#0B3B36" stroke-width="1.4"></path></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- FEATURED INSIGHT — WEEKLY COLUMN CAROUSEL -->
    {weeklyEditions.length > 0 && (
      <section data-screen-label="Featured insight" style="background:#F7F3EA;border-top:1px solid #E4DCC8;padding:80px 0;overflow:hidden;">
        <div style="max-width:1280px;margin:0 auto;padding:0 40px;">
          <div data-reveal style="display:flex;align-items:flex-end;justify-content:space-between;gap:24px;flex-wrap:wrap;margin-bottom:36px;">
            <div style="display:inline-flex;align-items:center;gap:10px;"><span style="width:26px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:#B8923D;">Featured Insight · Weekly Column</span></div>
            <a href="/weekly-insights/" class="ii-viewall" style="display:inline-flex;align-items:center;gap:9px;font-size:12px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:#0B3B36;text-decoration:none;transition:gap .25s;">All Weekly Insights
              <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M0 5h14M10 1l4 4-4 4" stroke="#0B3B36" stroke-width="1.4"></path></svg>
            </a>
          </div>

          <div class="ii-wc" data-reveal>
            <div class="ii-wc-track" id="ii-wc-track">
              {weeklyEditions.map((w, i) => (
                <div class={`ii-wc-slide${i === 0 ? ' on' : ''}`} data-wc={i}>
                  <div class="ii-wc-grid">
                    <div class="ii-wc-copy">
                      <div style="font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#B8923D;margin-bottom:18px;">{new Date(w.editionDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'long', year: 'numeric' })}</div>
                      <h2 style="font-family:'Playfair Display',serif;font-weight:700;font-size:38px;line-height:1.12;color:#0B3B36;margin-bottom:20px;text-wrap:balance;">{w.title}</h2>
                      <p style="font-size:16px;line-height:1.7;color:#5B584F;max-width:520px;margin-bottom:24px;">{w.excerpt}</p>
                      {w.author?.name && (
                        <div style="font-size:13px;color:#1C1C1A;margin-bottom:28px;"><span style="font-weight:600;">{w.author.name}</span>{w.author.role && <span style="color:#5B584F;">&nbsp;·&nbsp;{w.author.role}</span>}</div>
                      )}
                      <a href={`/weekly-insights/${w.slug}/`} class="ii-viewall" style="display:inline-flex;align-items:center;gap:9px;font-size:12px;font-weight:700;letter-spacing:.13em;text-transform:uppercase;color:#0B3B36;text-decoration:none;transition:gap .25s;">Read the Opinion
                        <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M0 5h14M10 1l4 4-4 4" stroke="#0B3B36" stroke-width="1.4"></path></svg>
                      </a>
                    </div>
                    <a href={`/weekly-insights/${w.slug}/`} class="ii-wc-cover">
                      <img src={urlFor(w.coverImage).width(760).height(950).auto('format').url()} alt={w.title} loading={i === 0 ? 'eager' : 'lazy'} />
                      <span class="ii-wc-badge">{w.editionLabel || 'Opinion · Weekly Column'}</span>
                    </a>
                  </div>
                </div>
              ))}
            </div>

            {weeklyEditions.length > 1 && (
              <div class="ii-wc-controls">
                <div class="ii-wc-dots" id="ii-wc-dots">
                  {weeklyEditions.map((_, i) => (
                    <button class={`ii-wc-dot${i === 0 ? ' on' : ''}`} data-wc-go={i} aria-label={`Weekly insight ${i + 1}`}></button>
                  ))}
                </div>
                <div class="ii-wc-arrows">
                  <button class="ii-wc-arrow" data-wc-dir="-1" aria-label="Previous"><svg width="16" height="12" viewBox="0 0 17 12" fill="none"><path d="M17 6H2M6 1L1 6l5 5" stroke="#0B3B36" stroke-width="1.5"></path></svg></button>
                  <button class="ii-wc-arrow" data-wc-dir="1" aria-label="Next"><svg width="16" height="12" viewBox="0 0 17 12" fill="none"><path d="M0 6h15M11 1l5 5-5 5" stroke="#0B3B36" stroke-width="1.5"></path></svg></button>
                </div>
              </div>
            )}
          </div>
        </div>
      </section>
    )}

  </div>
</SiteLayout>
