---
import SiteLayout from '../layouts/SiteLayout.astro';
---
<SiteLayout
  title="Contact — Iran Investment"
  description="Get in touch with Iran Investment — for enquiries, partnerships, and editorial."
>
  <div style="background:#F7F3EA;">
    <section style="max-width:1280px;margin:0 auto;padding:76px 40px 96px;">
      <div class="ii-contact-grid" style="display:grid;grid-template-columns:1fr 1.1fr;gap:72px;align-items:start;">
        <!-- LEFT: intro + details -->
        <div>
          <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;"><span style="width:26px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:#B8923D;">Get in Touch</span></div>
          <h1 style="font-family:'Playfair Display',serif;font-weight:700;font-size:46px;line-height:1.08;color:#0B3B36;margin-bottom:20px;">Let's talk.</h1>
          <p style="font-size:16px;line-height:1.7;color:#5B584F;margin-bottom:36px;max-width:420px;">Enquiries, partnerships, or editorial — send a note and we'll get back to you.</p>

          <div style="display:flex;flex-direction:column;gap:22px;">
            <div>
              <div style="font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#B8923D;margin-bottom:6px;">Email</div>
              <a href="mailto:hello@iraninvestment.com" style="font-size:16px;color:#0B3B36;text-decoration:none;">hello@iraninvestment.com</a>
            </div>
            <div>
              <div style="font-size:10px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:#B8923D;margin-bottom:6px;">Newsletter</div>
              <button class="ii-open-modal" data-modal="subscribe" style="background:none;border:none;padding:0;cursor:pointer;font-family:'Inter';font-size:16px;color:#0B3B36;text-decoration:underline;text-underline-offset:3px;text-decoration-color:#D9BE84;">Subscribe for weekly intelligence</button>
            </div>
          </div>
        </div>

        <!-- RIGHT: form (Netlify Forms) -->
        <div style="background:#FBF9F3;border:1px solid #E4DCC8;border-radius:6px;padding:40px 38px;">
          <form name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/contact/?sent=1">
            <input type="hidden" name="form-name" value="contact" />
            <p style="display:none;"><label>Don't fill this out: <input name="bot-field" /></label></p>

            <label class="ii-field-label">Name
              <input type="text" name="name" required class="ii-field" />
            </label>
            <label class="ii-field-label">Email
              <input type="email" name="email" required class="ii-field" />
            </label>
            <label class="ii-field-label">Company <span style="color:#9a9484;font-weight:400;text-transform:none;letter-spacing:0;">(optional)</span>
              <input type="text" name="company" class="ii-field" />
            </label>
            <label class="ii-field-label">Message
              <textarea name="message" rows="5" required class="ii-field" style="resize:vertical;"></textarea>
            </label>
            <button type="submit" class="ii-modal-cta" style="margin-top:8px;">Send message</button>
          </form>
          <div id="ii-contact-sent" style="display:none;margin-top:18px;padding:14px 16px;border-radius:4px;background:rgba(31,122,77,.1);border:1px solid rgba(31,122,77,.35);font-size:13.5px;color:#1F7A4D;">
            Thanks — your message has been sent. We'll be in touch shortly.
          </div>
        </div>
      </div>
    </section>
  </div>
</SiteLayout>

<style is:global>
  .ii-field-label{display:block;font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#5B584F;margin-bottom:22px;}
  .ii-field{display:block;width:100%;margin-top:9px;background:#F7F3EA;border:1px solid #D9CFB5;border-radius:4px;padding:13px 14px;font-family:'Inter';font-size:15px;color:#1C1C1A;letter-spacing:normal;text-transform:none;font-weight:400;transition:border-color .2s;}
  .ii-field:focus{outline:none;border-color:#0B3B36;}
  @media (max-width: 820px) {
    .ii-contact-grid { grid-template-columns: 1fr !important; gap: 44px !important; }
  }
</style>

<script>
  if (new URLSearchParams(window.location.search).get('sent') === '1') {
    const form = document.querySelector('form[name="contact"]');
    const ok = document.getElementById('ii-contact-sent');
    if (form) form.style.display = 'none';
    if (ok) ok.style.display = 'block';
  }
</script>
