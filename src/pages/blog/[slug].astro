---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { posts, categories, coverImage, badgeClass, postSlug } from '../../data/posts';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props as { post: (typeof posts)[number] };
const m = categories[post.cat];
const dt = new Date(post.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
const more = posts.filter((p) => p.cat === post.cat && p.id !== post.id).slice(0, 3);
const brightIds = [4, 9];
const ovStyle = brightIds.includes(post.id)
  ? 'background:linear-gradient(to bottom,rgba(0,0,0,.25) 0%,rgba(44,6,79,.65) 55%,rgba(20,3,35,.98) 100%)'
  : '';
---
<BaseLayout title={`${post.title} — Iran Investments`} description={post.excerpt}>
  <div class="art-cover" style={`background-image:url('${coverImage(post.id)}');background-size:cover`}>
    <div class="art-cov-ov" style={ovStyle}></div>
    <div class="art-cov-in">
      <span class={`a-badge ${badgeClass(post.cat)}`}>{m.label}</span>
      <h1>{post.title}</h1>
      <div class="art-meta-line"><span>{dt}</span><span class="art-meta-dot"></span><span>{post.rt}</span></div>
    </div>
  </div>
  <div class="art-wrap">
    <button class="art-back" onclick={`location.href='/blog/category/${post.cat}/'`}>← Back to {m.label}</button>
    <Fragment set:html={post.body} />
  </div>
  {more.length > 0 && (
    <div class="art-more">
      <div class="art-more-inner">
        <div style="font-size:11px;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--red);margin-bottom:24px">More in {m.label}</div>
        <div class="art-more-grid">
          {more.map((p) => <PostCard post={p} grid />)}
        </div>
      </div>
    </div>
  )}
</BaseLayout>
