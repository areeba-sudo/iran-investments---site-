---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getPostsByCategory, type Category } from '../../lib/sanity';
import categories from '../../data/categories.json';

const cats: Category[] = ['investment', 'hidden', 'strategy'];
const sections = await Promise.all(
  cats.map(async (s) => ({ cat: s, meta: categories[s], posts: await getPostsByCategory(s) }))
);
---
<BaseLayout title="Our Content — Iran Investments" description="Three categories. One mission. Intelligence that moves you.">
  <div class="cp-hero">
    <div class="st">Our Content</div>
    <h1>Intelligence That <em style="background:linear-gradient(90deg,#eb5e3e,#c43e20,#ff7050,#eb5e3e);background-size:200%;-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;animation:shimmer 3.5s linear infinite">Moves You.</em></h1>
    <p>Three categories. One mission.</p>
  </div>

  {sections.map(({ cat, meta, posts }) => (
    <div class="cp-sec">
      <div class="cp-sec-inner">
        <div class="cp-sec-hd">
          <div class="cp-sec-hd-left">
            <div class="st">{meta.label}</div>
            <h2>{meta.label}</h2>
            <p>{meta.desc}</p>
          </div>
          <div class="sl-btns">
            <button class="sl-btn" onclick={`cpSlide('${cat}',-1)`}>←</button>
            <button class="sl-btn" onclick={`cpSlide('${cat}',1)`}>→</button>
          </div>
        </div>
        <div class="sl-outer">
          <div class="sl-track" id={`cpt-${cat}`}>
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        </div>
        <button class="view-all-btn" onclick={`location.href='/blog/category/${cat}/'`}>View All {meta.label} →</button>
      </div>
    </div>
  ))}

  <script>
    import { initBlogIndex } from '../../scripts/blogIndex.js';
    document.addEventListener('DOMContentLoaded', () => {
      initBlogIndex();
    });
  </script>
</BaseLayout>
