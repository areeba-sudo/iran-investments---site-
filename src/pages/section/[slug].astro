---
import SiteLayout from '../../layouts/SiteLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import FeaturedDownloadBanner from '../../components/FeaturedDownloadBanner.astro';
import SubscribeStrip from '../../components/SubscribeStrip.astro';
import { getLiveSections, getPostsBySection, getTopicsBySection, urlFor, type SectionDoc } from '../../lib/sanity';

export async function getStaticPaths() {
  const sections = await getLiveSections();
  return sections.map((section) => ({ params: { slug: section.slug }, props: { section } }));
}

const { section } = Astro.props as { section: SectionDoc };
const [posts, topics] = await Promise.all([
  getPostsBySection(section.slug),
  getTopicsBySection(section.slug),
]);
const hasTabs = topics.length > 0;
const [lead, ...rest] = posts;
const leadDate = lead
  ? new Date(lead.publishedDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })
  : '';
const leadImg = lead?.coverImage ? urlFor(lead.coverImage).width(1200).height(820).auto('format').url() : '';
---
<SiteLayout
  title={`${section.title} — Iran Investment`}
  description={section.description || `Articles in ${section.title} from Iran Investment.`}
>
  <div style="background:#F7F3EA;">
    <!-- SECTION HEADER -->
    <section style="background:#0B3B36;position:relative;overflow:hidden;">
      <div style="position:absolute;width:320px;height:320px;top:-120px;right:-40px;border-radius:50%;background:radial-gradient(circle,rgba(217,190,132,.18),transparent 68%);filter:blur(30px);pointer-events:none;"></div>
      <div style="max-width:1280px;margin:0 auto;padding:80px 40px 60px;position:relative;">
        <nav style="display:flex;align-items:center;gap:9px;font-size:11px;letter-spacing:.08em;text-transform:uppercase;color:rgba(247,243,234,.5);margin-bottom:26px;">
          <a href="/" style="color:rgba(247,243,234,.5);text-decoration:none;">Home</a>
          <span>›</span>
          <a href="/blog/" style="color:rgba(247,243,234,.5);text-decoration:none;">Articles</a>
          <span>›</span>
          <span style="color:#D9BE84;">{section.title}</span>
        </nav>
        <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:18px;"><span style="width:26px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.26em;text-transform:uppercase;color:#D9BE84;">Section</span></div>
        <h1 style="font-family:'Playfair Display',serif;font-weight:700;font-size:52px;line-height:1.05;color:#F7F3EA;margin-bottom:16px;max-width:760px;">{section.title}</h1>
        {section.description && <p style="font-size:16.5px;line-height:1.65;color:rgba(247,243,234,.72);max-width:600px;">{section.description}</p>}
      </div>
    </section>

    {posts.length === 0 ? (
      <section style="max-width:1280px;margin:0 auto;padding:64px 40px 96px;">
        <div style="border:1px dashed #C9BF9F;border-radius:6px;padding:64px 40px;text-align:center;">
          <div style="font-family:'Playfair Display',serif;font-weight:600;font-size:22px;color:#0B3B36;">No articles in this section yet.</div>
        </div>
      </section>
    ) : hasTabs ? (
      <section style="max-width:1280px;margin:0 auto;padding:40px 40px 88px;">
        <div class="ii-tabs-wrap">
          <div class="ii-tabs" role="tablist">
            <button class="ii-tab on" data-tab="all">All</button>
            {topics.map((t) => (
              <button class="ii-tab" data-tab={t.slug}>{t.title}</button>
            ))}
          </div>
        </div>
        <div class="ii-cards-grid ii-tab-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:40px;">
          {posts.map((post, i) => (
            <ArticleCard post={post} eager={i < 3} />
          ))}
        </div>
        <div class="ii-tab-empty" style="display:none;border:1px dashed #C9BF9F;border-radius:6px;padding:56px 40px;text-align:center;margin-top:40px;">
          <div style="font-family:'Playfair Display',serif;font-weight:600;font-size:20px;color:#0B3B36;">No articles in this tab yet.</div>
        </div>
      </section>
    ) : (
      <>
        <!-- LEAD ARTICLE -->
        <section style="max-width:1280px;margin:0 auto;padding:56px 40px 8px;">
          <a href={`/blog/${lead.slug}/`} class="ii-lead" data-reveal style="display:grid;grid-template-columns:1.15fr 1fr;gap:44px;align-items:center;text-decoration:none;">
            <div style="aspect-ratio:3/2;border-radius:5px;overflow:hidden;background:#0B3B36;">
              {leadImg && <img src={leadImg} alt={lead.title} style="width:100%;height:100%;object-fit:cover;filter:saturate(.9);" />}
            </div>
            <div>
              <div style="display:inline-flex;align-items:center;gap:10px;margin-bottom:16px;"><span style="width:22px;height:1px;background:#B8923D;"></span><span style="font-size:11px;font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:#B8923D;">Lead Story</span></div>
              <h2 style="font-family:'Playfair Display',serif;font-weight:700;font-size:34px;line-height:1.12;color:#0B3B36;margin-bottom:16px;text-wrap:balance;">{lead.title}</h2>
              <p style="font-size:16px;line-height:1.68;color:#5B584F;margin-bottom:20px;">{lead.excerpt}</p>
              <div style="display:flex;align-items:center;gap:10px;font-size:12.5px;color:#5B584F;">
                {lead.author?.name && <span style="font-weight:600;color:#1C1C1A;">{lead.author.name}</span>}
                {lead.author?.name && <span style="width:3px;height:3px;border-radius:50%;background:#B8923D;"></span>}
                <span>{leadDate}</span>
                {lead.readTime && <span style="width:3px;height:3px;border-radius:50%;background:#B8923D;"></span>}
                {lead.readTime && <span>{lead.readTime}</span>}
              </div>
            </div>
          </a>
        </section>

        <!-- REST GRID -->
        {rest.length > 0 && (
          <section style="max-width:1280px;margin:0 auto;padding:44px 40px 40px;">
            <div style="border-top:1px solid #E4DCC8;padding-top:44px;">
              <div class="ii-cards-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:28px;">
                {rest.map((post) => (
                  <ArticleCard post={post} />
                ))}
              </div>
            </div>
          </section>
        )}
      </>
    )}

    <!-- EDITABLE FEATURED-DOWNLOAD BANNER -->
    <FeaturedDownloadBanner data={section.featuredDownload} />

    <SubscribeStrip />
  </div>
</SiteLayout>

<style is:global>
  /* ---- section tabs ---- */
  .ii-tabs-wrap { border-bottom: 1px solid #E4DCC8; overflow-x: auto; -webkit-overflow-scrolling: touch; scrollbar-width: none; }
  .ii-tabs-wrap::-webkit-scrollbar { display: none; }
  .ii-tabs { display: flex; gap: 2px; min-width: max-content; }
  .ii-tab { background: none; border: none; cursor: pointer; font-family: 'Inter'; font-size: 12px; font-weight: 600; letter-spacing: .09em; text-transform: uppercase; color: #8a8676; padding: 14px 18px; border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: color .25s, border-color .25s; }
  .ii-tab:hover { color: #0B3B36; }
  .ii-tab.on { color: #0B3B36; border-bottom-color: #B8923D; }
  @media (max-width: 1000px) {
    .ii-cards-grid { grid-template-columns: repeat(2, 1fr) !important; }
  }
  @media (max-width: 820px) {
    .ii-lead { grid-template-columns: 1fr !important; gap: 24px !important; }
    .ii-lead h2 { font-size: 27px !important; }
  }
  @media (max-width: 640px) {
    .ii-cards-grid { grid-template-columns: 1fr !important; }
  }
</style>
